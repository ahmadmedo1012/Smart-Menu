# ── Required ──────────────────────────────────
DATABASE_URL="postgresql://user:pass@host:5432/db"
JWT_SECRET="your-random-secret-at-least-32-chars"
NEXT_PUBLIC_DOMAIN="https://your-app.vercel.app"

# ── Optional (but recommended) ────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="+218000000000"
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_CHAT_ID="-1001234567890"
AUTH_SECRET="another-random-secret"
DATABASE_SCHEMA="public"

# ── Telegram Interactive Engine ───────────────
# TELEGRAM_WEBHOOK_SECRET  — random string; passed as secret_token to setWebhook.
#                              Telegram sends it back as X-Telegram-Bot-Api-Secret-Token
#                              header on every webhook POST. Required in production.
# TELEGRAM_ADMIN_IDS       — comma-separated Telegram user IDs whose button taps are
#                            authorized to approve/reject subscription payments.
#                            Set to the actual Telegram numeric ID of each admin.
# TELEGRAM_WEBHOOK_SECRET=""
# TELEGRAM_ADMIN_IDS="123456789,987654321"
