generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int         @id @default(autoincrement())
  username     String      @unique
  password     String
  name         String
  role         String      @default("admin") // "admin" or "owner"
  restaurantId Int?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  planId       Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([restaurantId])
}

model SubscriptionPlan {
  id          Int           @id @default(autoincrement())
  name        String
  nameAr      String
  price       Float         @default(0)
  periodDays  Int           @default(30)
  features    String        @default("[]")
  maxMenus    Int           @default(1)
  maxItems    Int           @default(50)
  maxOrders   Int           @default(500)
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  restaurants Restaurant[]
}

model Restaurant {
  id           Int            @id @default(autoincrement())
  name         String
  slug         String         @unique
  description  String         @default("")
  logo         String         @default("")
  phone        String         @default("")
  whatsapp     String         @default("")
  email        String         @default("")
  address      String         @default("")
  workingHours String         @default("")
  themeColor   String         @default("amber")
  currency     String         @default("LYD")
  isActive     Boolean        @default(true)
  planId       Int?
  plan         SubscriptionPlan? @relation(fields: [planId], references: [id])
  planStart    DateTime?
  planEnd      DateTime?
  maxItemsLimit Int           @default(50)
  maxOrdersLimit Int          @default(500)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  users        User[]
  categories   MenuCategory[]
  orders       Order[]
  settings     Setting[]
  loyaltyCards  LoyaltyCard[]
}

model MenuCategory {
  id           Int        @id @default(autoincrement())
  name         String
  nameAr       String?
  icon         String     @default("")
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model MenuItem {
  id              Int         @id @default(autoincrement())
  name            String
  nameAr          String?
  description     String      @default("")
  descriptionAr   String      @default("")
  price           Float
  discountedPrice Float?
  image           String      @default("")
  status          String      @default("available")
  sortOrder       Int         @default(0)
  categoryId      Int
  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([categoryId])
  @@index([status])
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNo       String      @unique
  customerName  String      @default("")
  customerPhone String      @default("")
  notes         String      @default("")
  pickupType    String      @default("inside")
  status        String      @default("new")
  subtotal      Float
  discount      Float       @default(0)
  total         Float
  whatsappSent  Boolean     @default(false)
  restaurantId  Int
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id       Int      @id @default(autoincrement())
  quantity Int      @default(1)
  notes    String   @default("")
  price    Float
  orderId  Int
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId   Int
  item     MenuItem @relation(fields: [itemId], references: [id])

  @@index([orderId])
  @@index([itemId])
}

model Setting {
  id           Int        @id @default(autoincrement())
  key          String
  value        String     @default("")
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, key])
  @@index([restaurantId])
}

model WhatsappTemplate {
  id           Int      @id @default(autoincrement())
  name         String
  template     String   @default("")
  isActive     Boolean  @default(true)
  restaurantId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LoyaltyCard {
  id            Int        @id @default(autoincrement())
  customerPhone String
  customerName  String     @default("")
  totalOrders   Int        @default(1)
  totalSpent    Float      @default(0)
  points        Int        @default(0)
  tier          String     @default("bronze") // bronze, silver, gold, platinum
  referralCode  String     @unique
  restaurantId  Int
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([customerPhone, restaurantId])
  @@index([restaurantId])
  @@index([referralCode])
}

model Referral {
  id                Int         @id @default(autoincrement())
  referralCode      String
  referrerId        Int
  referredPhone     String      @default("")
  referredName      String      @default("")
  status            String      @default("pending")
  discountPercent   Int         @default(10)
  referrerRewardPct Int         @default(10)
  orderId           Int?
  createdAt         DateTime    @default(now())
  convertedAt       DateTime?

  @@index([referralCode])
}

model RewardTransaction {
  id            Int         @id @default(autoincrement())
  cardId        Int
  type          String      @default("earn")
  points        Int
  description   String      @default("")
  orderId       Int?
  restaurantId  Int
  createdAt     DateTime    @default(now())

  @@index([cardId])
}
