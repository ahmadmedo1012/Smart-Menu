generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  owner
}

enum ItemStatus {
  available
  unavailable
}

enum OrderStatus {
  new
  preparing
  ready
  completed
  cancelled
}

enum PickupType {
  inside
  takeaway
  delivery
}

enum LoyaltyTier {
  bronze
  silver
  gold
  platinum
}

enum ReferralStatus {
  pending
  converted
  expired
}

enum RewardType {
  earn
  redeem
}

model User {
  id           Int               @id @default(autoincrement())
  username     String            @unique
  password     String
  name         String
  role         Role              @default(owner)
  restaurantId Int?
  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  planId       Int?
  plan         SubscriptionPlan? @relation(fields: [planId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([restaurantId])
  @@index([planId])
}

model SubscriptionPlan {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  nameAr      String
  price       Decimal      @default(0) @db.Decimal(10, 2)
  periodDays  Int          @default(30)
  features    String       @default("[]")
  maxMenus    Int          @default(1)
  maxItems    Int          @default(50)
  maxOrders   Int          @default(500)
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurants Restaurant[]
  users       User[]
}

model Restaurant {
  id                 Int                 @id @default(autoincrement())
  name               String
  slug               String              @unique
  description        String              @default("")
  gallery            String[]            @default([])
  logo               String              @default("")
  phone              String              @default("")
  whatsapp           String              @default("")
  email              String              @default("")
  address            String              @default("")
  workingHours       String              @default("")
  themeColor         String              @default("amber")
  currency           String              @default("LYD")
  isActive           Boolean             @default(true)
  planId             Int?
  plan               SubscriptionPlan?   @relation(fields: [planId], references: [id])
  planStart          DateTime?
  planEnd            DateTime?
  maxItems           Int                 @default(50)
  maxOrders          Int                 @default(500)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              User[]
  categories         MenuCategory[]
  orders             Order[]

  @@index([planId])
  settings           Setting[]
  loyaltyCards       LoyaltyCard[]
  referrals          Referral[]
  rewardTransactions RewardTransaction[]
  whatsappTemplates  WhatsappTemplate[]
}

model MenuCategory {
  id           Int        @id @default(autoincrement())
  name         String
  nameAr       String?
  icon         String     @default("")
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model MenuItem {
  id              Int          @id @default(autoincrement())
  name            String
  nameAr          String?
  description     String       @default("")
  descriptionAr   String       @default("")
  price           Decimal      @db.Decimal(10, 2)
  discountedPrice Decimal?     @db.Decimal(10, 2)
  image           String       @default("")
  status          ItemStatus   @default(available)
  sortOrder       Int          @default(0)
  categoryId      Int
  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([categoryId])
  @@index([status])
}

model Order {
  id                 Int                 @id @default(autoincrement())
  orderNo            String              @unique
  customerName       String              @default("")
  customerPhone      String              @default("")
  notes              String              @default("")
  pickupType         PickupType          @default(inside)
  status             OrderStatus         @default(new)
  subtotal           Decimal             @db.Decimal(10, 2)
  discount           Decimal             @default(0) @db.Decimal(10, 2)
  total              Decimal             @db.Decimal(10, 2)
  whatsappSent       Boolean             @default(false)
  restaurantId       Int
  restaurant         Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  items              OrderItem[]
  referrals          Referral[]
  rewardTransactions RewardTransaction[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([restaurantId, status])
  @@index([customerPhone])
  @@index([createdAt])
}

model OrderItem {
  id       Int      @id @default(autoincrement())
  quantity Int      @default(1)
  notes    String   @default("")
  price    Decimal  @db.Decimal(10, 2)
  orderId  Int
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId   Int
  item     MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([itemId])
}

model Setting {
  id           Int        @id @default(autoincrement())
  key          String
  value        String     @default("")
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, key])
  @@index([restaurantId])
}

model WhatsappTemplate {
  id           Int        @id @default(autoincrement())
  name         String
  template     String     @default("")
  isActive     Boolean    @default(true)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model LoyaltyCard {
  id            Int         @id @default(autoincrement())
  customerPhone String
  customerName  String      @default("")
  totalOrders   Int         @default(1)
  totalSpent    Decimal     @default(0) @db.Decimal(10, 2)
  points        Int         @default(0)
  tier          LoyaltyTier @default(bronze)
  referralCode  String      @unique
  restaurantId  Int
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  referrals          Referral[]
  rewardTransactions RewardTransaction[]

  @@unique([customerPhone, restaurantId])
  @@index([restaurantId])
  @@index([referralCode])
}

model Referral {
  id                Int            @id @default(autoincrement())
  referralCode      String
  referrerId        Int
  referrer          LoyaltyCard    @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredPhone     String         @default("")
  referredName      String         @default("")
  status            ReferralStatus @default(pending)
  discountPercent   Int            @default(10)
  referrerRewardPct Int            @default(10)
  orderId           Int?
  order             Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  restaurantId      Int
  restaurant        Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  convertedAt       DateTime?

  @@index([referralCode])
  @@index([referrerId])
  @@index([referrerId, status])
}

model RewardTransaction {
  id           Int         @id @default(autoincrement())
  cardId       Int
  card         LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  type         RewardType  @default(earn)
  points       Int
  description  String      @default("")
  orderId      Int?
  order        Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  restaurantId Int
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@index([cardId])
  @@index([restaurantId])
  @@index([cardId, createdAt])
}
