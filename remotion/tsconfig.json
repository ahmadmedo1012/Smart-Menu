{
  "compilerOptions": {
    "target": "ES2018",
    "module": "commonjs",
    "jsx": "react-jsx",
    "outDir": "./dist",
    "strict": true,
    "noEmit": true,
    "lib": ["es2015"],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
